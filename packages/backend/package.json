{
  "name": "@eva/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "seed": "ts-node src/database/seeds/seed.ts",
    "typeorm": "node --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm run typeorm -- migration:generate src/database/migrations/AutoGeneratedMigration -d src/database/data-source.ts",
    "migration:run": "pnpm run typeorm -- migration:run -d src/database/data-source.ts",
    "migration:revert": "pnpm run typeorm -- migration:revert -d src/database/data-source.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@eva/shared": "workspace:*",
    "@nestjs/bull": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@sentry/node": "^10.22.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.4.0",
    "bull": "^4.16.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bull": "^4.10.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/passport-jwt": "^4.0.0",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-loader": "^9.5.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
