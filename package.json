{
  "name": "eva",
  "version": "1.0.0",
  "private": true,
  "description": "Eva AI Evaluation Platform",
  "scripts": {
    "build:shared": "pnpm --filter @eva/shared build",
    "dev:frontend": "pnpm run build:shared && pnpm --filter @eva/frontend dev",
    "dev:backend": "pnpm run build:shared && pnpm --filter @eva/backend start:dev",
    "dev": "pnpm run dev:frontend & pnpm run dev:backend",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:migrate": "pnpm --filter @eva/backend migration:run",
    "db:revert": "pnpm --filter @eva/backend migration:revert"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
